pipeline {
	agent any
	tools {
		maven "maven"
	}
	stages {
		stage("Checkout") {
			steps {
				git branch: "master", url: "https://github.com/prajwalknaik/m1.git"
			}
		}
		stage("Build") {
			steps {
				sh "mvn compile"
			}
		}
		stage("Test") {
			steps {
				sh "mvn test"
			}
		}
		stage("Run Application") {
			steps {
				sh "java -jar target/my-maven-app-1.0-SNAPSHOT.jar"
			}
		}
	}
	post {
		success {
			echo "Build and deployment successful"
		}
		failure {
			echo "Build Failed"
		}
	}
}
